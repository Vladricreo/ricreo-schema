/// Modello per il profilo di un utente, con informazioni aggiuntive come la biografia.
model Profile {
  id        Int     @id @default(autoincrement())
  bio       String?
  avatarUrl String?
  language  String? @default("it")
  userId    Int     @unique ///
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@schema("public")
}

/// Modello per gli utenti del sistema. Gestisce l'autenticazione e le informazioni di base dell'utente.
model User {
  id                        Int                 @id @default(autoincrement())
  email                     String              @unique
  username                  String              @unique
  password                  String
  name                      String?
  isActive                  Boolean             @default(true)
  /// Ordine di intervento nella distribuzione automatica degli ordini di assemblaggio.
  /// Valore minore = riempito prima (es. operatore dedicato = 0, backup = 1).
  /// Se NULL, viene derivato dai ruoli RBAC (Assemblatore senza GestoreStampanti = dedicato).
  assemblyInterventionOrder Int?                @db.SmallInt
  createdAt                 DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  posts                     Post[]
  profile                   Profile?
  roles                     UserRole[]
  OdetteMove                OdetteMove[]
  OdetteCleaningLog         OdetteCleaningLog[]
  movements                 Movement[]
  productOrders             ProductOrder[]
  assemblyOrders            AssemblyOrder[]
  /// Ordini di assemblaggio pianificati (assegnati) a questo utente.
  /// Distinto da `assemblyOrders` (chi ha eseguito): qui è "pianificato per".
  assignedAssemblyOrders    AssemblyOrder[]     @relation("AssemblyOrderAssignedTo")
  /// Turni di lavoro ricorrenti settimanali per la distribuzione degli assemblaggi.
  workShifts                WorkShift[]
  /// Giorni di assenza puntuali (ferie, malattia, ecc.): in quel giorno capacità = 0 in distribuzione.
  workAbsences              WorkAbsence[]
  performedOperations       AssemblyOperation[]
  lotInspections            LotInspection[]

  /// Operazioni di raccolta pezzi effettuate da questo utente
  printerHarvests      PrinterHarvest[]      @relation("PrinterHarvests")
  /// Operazioni di carico filamento effettuate da questo utente
  printerFilamentLoads PrinterFilamentLoad[] @relation("PrinterFilamentLoads")

  /// Notifiche create da questo utente (audit/actor).
  notificationsCreated   Notification[]          @relation("NotificationCreatedBy")
  /// Stato notifiche ricevute da questo utente.
  notificationRecipients NotificationRecipient[]

  /// Notifiche Print Farm create da questo utente (audit/actor).
  printFarmNotificationsCreated    PrintFarmNotification[]           @relation("PrintFarmNotificationCreatedBy")
  /// Stato notifiche Print Farm ricevute da questo utente.
  printFarmNotificationRecipients  PrintFarmNotificationRecipient[]
  /// Preferenze notifiche Print Farm per questo utente.
  printFarmNotificationPreferences PrintFarmNotificationPreference[]

  /// Override di spec approvati da questo utente (audit).
  approvedItemSpecOverrides ItemSpecOverride[] @relation("ApprovedItemSpecOverrides")

  /// Righe picking effettuate da questo utente.
  pickingLines PickingLine[]

  /// Resi creati da questo utente (audit).
  customerReturns CustomerReturn[]

  @@index([isActive]) /// Indice pratico per filtri frequenti
  @@schema("public") ///  la tabella degli utenti
}

model Role {
  id                           String           @id @default(uuid()) @db.Uuid
  name                         String           @unique
  description                  String?
  /// Se true, gli utenti con questo ruolo sono impiegati nell'assemblaggio
  /// e rientrano nella distribuzione automatica degli ordini.
  isAssemblyRole               Boolean          @default(false)
  /// Priorità di intervento del ruolo nella distribuzione (minore = riempito prima).
  /// Usata come default quando l'utente non ha un `assemblyInterventionOrder` esplicito.
  assemblyPriority             Int?             @db.SmallInt
  /// Se true, gli utenti con questo ruolo possono modificare le assegnazioni degli
  /// ordini di assemblaggio (vedono i controlli/avatar di assegnazione sulla board).
  canManageAssemblyAssignments Boolean          @default(false)
  createdAt                    DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt                    DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  users                        UserRole[]
  permissions                  RolePermission[]

  @@schema("public")
}

model UserRole {
  userId     Int
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@schema("public")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  roles       RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@schema("public")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@schema("public")
}

/// Segmento di turno di lavoro settimanale ricorrente per un utente.
/// Usato per stimare la capacità giornaliera nella distribuzione automatica degli ordini di assemblaggio.
/// Uno stesso giorno può avere più segmenti: le pause sono semplicemente gli intervalli
/// non coperti tra un segmento e l'altro (es. 10:00–12:00 e 13:00–17:00 = pausa 12:00–13:00).
model WorkShift {
  id          Int      @id @default(autoincrement())
  userId      Int
  /// Giorno della settimana: 0 = Domenica .. 6 = Sabato.
  dayOfWeek   Int      @db.SmallInt
  /// Inizio segmento in minuti dalla mezzanotte (es. 600 = 10:00).
  startMinute Int      @db.SmallInt
  /// Fine segmento in minuti dalla mezzanotte (es. 840 = 14:00). Deve essere > startMinute.
  endMinute   Int      @db.SmallInt
  /// Costo orario (€/h) del segmento. Il costo del segmento = hourlyCost × ore del segmento. Opzionale.
  cost        Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([dayOfWeek])
  @@schema("public")
}

/// Assenza puntuale di un operatore in un giorno di calendario.
/// In quel giorno la distribuzione assemblaggi non gli assegna ordini (capacità 0).
model WorkAbsence {
  id          Int      @id @default(autoincrement())
  userId      Int
  /// Giorno di assenza (solo data).
  absenceDate DateTime @db.Date
  note        String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, absenceDate])
  @@index([userId])
  @@index([absenceDate])
  @@schema("public")
}
