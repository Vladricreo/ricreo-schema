/// Registro degli interventi di manutenzione sulla stampante.
model PrinterMaintenanceLog {
  id        String  @id @default(uuid()) @db.Uuid
  /// Progressivo numerico leggibile (BIGINT Postgres) per uso umano/reportistica.
  /// Nota: lasciamo `id` UUID come PK per non rompere relazioni/migrazioni; questo è solo un numero sequenziale.
  number    BigInt  @unique @default(autoincrement()) @db.BigInt
  printerId String  @db.Uuid
  printer   Printer @relation(fields: [printerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  type        MaintenanceType @default(ORDINARY)
  description String

  performedAt DateTime @default(now()) @db.Timestamptz(6)
  performedBy String? // User ID

  cost        Decimal? @db.Decimal(12, 2) // Costo intervento/ricambi
  durationMin Int? // Durata intervento in minuti

  /// Workflow ISO: motivazione al toggle manutenzione, foto, errore, AI, sessione, PDF
  reason              String?
  photos              String[]                  @default([])
  lastErrorSnapshot   Json?
  aiAdvice            String?                   @db.Text
  aiAdviceModel       String?
  startedAt           DateTime?                 @db.Timestamptz(6)
  endedAt             DateTime?                 @db.Timestamptz(6)
  status              MaintenanceSessionStatus?
  pdfUrl              String?

  /// --- PIANIFICAZIONE / ISO ---
  /// Data/ora prevista per l'esecuzione (presente per log generati da pianificazione o programmati ad-hoc).
  /// NULL per interventi straordinari avviati al momento.
  scheduledFor DateTime? @db.Timestamptz(6)

  /// Pianificazione ricorrente che ha generato/governa questo log (se presente).
  planId String?                 @db.Uuid
  plan   PrinterMaintenancePlan? @relation(fields: [planId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  /// Snapshot della checklist al momento della creazione/esecuzione (lista step + esito per step).
  /// Formato: [{ id, label, required, done?, note? }, ...]
  checklist Json?

  /// Esito complessivo dell'intervento (compilato a chiusura, ISO 9001/14224).
  outcome      MaintenanceOutcome?
  outcomeNotes String?             @db.Text

  /// Verifica/approvazione (firma) di un secondo operatore - opzionale ma raccomandato ISO.
  verifiedBy String? // User ID o nome
  verifiedAt DateTime? @db.Timestamptz(6)

  chatMessages MaintenanceChatMessage[]
  /// Movimenti inventario (es. USO ricambi) collegati a questo log.
  movements Movement[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([printerId, scheduledFor])
  @@index([status, scheduledFor])
  @@index([planId])
  @@schema("print-farm")
}

/// Pianificazione manutenzione ricorrente o programmata (template ISO).
/// Una `PrinterMaintenancePlan` genera occorrenze concrete come `PrinterMaintenanceLog`
/// con `status=PENDING` e `scheduledFor` valorizzato. Solo all'avvio reale dell'intervento
/// la stampante viene messa in `manualOverrideStatus=MAINTENANCE`.
model PrinterMaintenancePlan {
  id     String @id @default(uuid()) @db.Uuid
  /// Progressivo leggibile per riferimenti umani (es. "Piano #42").
  number BigInt @unique @default(autoincrement()) @db.BigInt

  printerId String  @db.Uuid
  printer   Printer @relation(fields: [printerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Tipo intervento pianificato. In pratica ORDINARY o UPGRADE; gli altri tipi
  /// non si pianificano ma il vincolo è applicativo (non DB) per flessibilità futura.
  type MaintenanceType @default(ORDINARY)

  /// Titolo breve (es. "Pulizia hotend e calibrazione piatto").
  title String
  /// Procedura/descrizione dettagliata (rich text/markdown supportato lato UI).
  description String? @db.Text

  /// Checklist procedura (template ISO). Formato: [{ id, label, required }].
  /// All'esecuzione viene clonata sul log e popolata con lo stato `done`.
  checklistTemplate Json?

  /// Stima durata intervento (minuti) - per capacity planning e UI.
  estimatedDurationMin Int?

  /// Ricambi tipicamente usati (suggerimento operatore). Formato: [{ itemId, quantity }].
  suggestedParts Json?

  /// --- RICORRENZA ---
  recurrenceMode MaintenanceRecurrenceMode @default(NONE)
  /// Numero di unità tra un'occorrenza e la successiva (giorni / settimane / mesi / anni).
  /// Esempio: recurrenceMode=MONTHLY, intervalValue=1 → ogni mese.
  intervalValue  Int?
  /// Tolleranza in giorni prima di considerare la pianificazione "in ritardo" (highlight rosso UI).
  graceDays      Int?                      @default(7)
  /// Data di riferimento (es. installazione macchina) per calcolare la prossima scadenza.
  anchorDate     DateTime?                 @db.Timestamptz(6)

  /// Prossima scadenza prevista. Aggiornata automaticamente al completamento dell'occorrenza.
  /// Per piani NONE (una tantum) coincide con la data di esecuzione singola.
  nextDueAt       DateTime? @db.Timestamptz(6)
  /// Ultimo trigger eseguito (=performedAt dell'ultimo log COMPLETED collegato).
  lastTriggeredAt DateTime? @db.Timestamptz(6)

  /// Giorni prima della scadenza in cui inviare il reminder/notifica.
  remindBeforeDays Int @default(3)

  /// Pianificazione attiva (se false, non genera nuove occorrenze ma resta visibile).
  active Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  /// Utente (User ID) che ha creato/modificato l'ultima volta il piano (audit ISO).
  createdBy String?
  updatedBy String?

  /// Occorrenze (log) generate da questo piano.
  logs PrinterMaintenanceLog[]

  @@index([printerId, active])
  @@index([nextDueAt])
  @@schema("print-farm")
}

/// Messaggi chat AI collegati a un intervento di manutenzione (normativa / supporto operatore).
model MaintenanceChatMessage {
  id String @id @default(uuid()) @db.Uuid

  maintenanceLogId String                @db.Uuid
  maintenanceLog   PrinterMaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  role    MaintenanceChatRole
  content String              @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([maintenanceLogId, createdAt])
  @@schema("print-farm")
}

/// Issue "attiva" o storicizzata legata a una stampante.
/// A differenza di `PrinterLogs` (log puntuale di un ErrorCode), questa tabella serve a rappresentare
/// condizioni operative che bloccano la produzione (es. FILAMENT out, BED da scaricare, rete offline),
/// con lifecycle OPEN -> ACKED -> RESOLVED e aggiornamento `lastSeenAt`.
model PrinterIssue {
  id     String @id @default(uuid()) @db.Uuid
  /// Progressivo numerico leggibile (BIGINT Postgres) per uso umano/reportistica.
  /// Nota: lasciamo `id` UUID come PK per non rompere relazioni/migrazioni; questo è solo un numero sequenziale.
  number BigInt @unique @default(autoincrement()) @db.BigInt

  printerId String  @db.Uuid
  printer   Printer @relation(fields: [printerId], references: [id], onDelete: Cascade)

  /// Se l'issue è correlata a un assignment specifico (stampa/coda).
  assignmentId String?            @db.Uuid
  assignment   PrinterAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  source   PrinterIssueSource   @default(MQTT)
  category PrinterIssueCategory
  status   PrinterIssueStatus   @default(OPEN)
  severity ErrorSeverity        @default(WARNING)

  /// Collegamento opzionale a una tabella di codici noti.
  errorCodeId Int?
  errorCode   ErrorCode? @relation(fields: [errorCodeId], references: [id], onDelete: SetNull)

  /// Codice esterno (es. raw code MQTT) se non mappato a ErrorCode.
  externalCode String?
  message      String?

  /// Quando l'issue è stata vista la prima volta / aggiornata.
  openedAt   DateTime @default(now()) @db.Timestamptz(6)
  lastSeenAt DateTime @default(now()) @db.Timestamptz(6)

  /// Gestione operativa
  acknowledgedAt DateTime? @db.Timestamptz(6)
  acknowledgedBy String? // User ID
  resolvedAt     DateTime? @db.Timestamptz(6)
  resolvedBy     String? // User ID

  /// Payload/contesto (raw MQTT/WSS, snapshot, ecc.)
  metadata Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([printerId, status])
  @@index([printerId, category, status])
  @@index([assignmentId])
  @@index([errorCodeId])
  @@index([lastSeenAt])
  @@schema("print-farm")
}

/// Registro puntuale degli scarti/errori.
/// Permette di analizzare le cause di fallimento e ricalcolare i job.
model PrintFailureLog {
  id     String @id @default(uuid()) @db.Uuid
  /// Progressivo numerico leggibile (BIGINT Postgres) per uso umano/reportistica.
  /// Nota: lasciamo `id` UUID come PK per non rompere relazioni/migrazioni; questo è solo un numero sequenziale.
  number BigInt @unique @default(autoincrement()) @db.BigInt

  productionJobId String        @db.Uuid
  productionJob   ProductionJob @relation(fields: [productionJobId], references: [id])

  printerId String  @db.Uuid
  printer   Printer @relation(fields: [printerId], references: [id])

  /// Opzionale: se il fallimento è avvenuto durante una run specifica
  printRunId String?   @db.Uuid
  printRun   PrintRun? @relation(fields: [printRunId], references: [id])

  quantityScrapped Int           @default(1)
  reason           FailureReason @default(OTHER)
  notes            String?

  reportedAt DateTime @default(now()) @db.Timestamptz(6)
  reportedBy String? // User ID

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@schema("print-farm")
}

/// Feedback degli operatori su stampanti o file.
/// Es: "Questa stampante fa rumore", "Questo file ha supporti impossibili".
model FarmFeedback {
  id     String @id @default(uuid()) @db.Uuid
  /// Progressivo numerico leggibile (BIGINT Postgres) per uso umano/reportistica.
  /// Nota: lasciamo `id` UUID come PK per non rompere relazioni/migrazioni; questo è solo un numero sequenziale.
  number BigInt @unique @default(autoincrement()) @db.BigInt

  type     FeedbackType     @default(GENERAL)
  priority FeedbackPriority @default(NORMAL)
  status   FeedbackStatus   @default(OPEN)

  description String

  // Il feedback può essere collegato a una stampante E/O a un file
  printerId String?  @db.Uuid
  printer   Printer? @relation(fields: [printerId], references: [id])

  fileId String?             @db.Uuid
  file   ProjectThreeMFFile? @relation(fields: [fileId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  reportedBy String? // User ID
  resolvedBy String? // User ID

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@schema("print-farm")
}

enum MaintenanceType {
  ORDINARY // Manutenzione ordinaria (pulizia, lubrificazione, controlli periodici, calibrazioni)
  EXTRAORDINARY // Manutenzione straordinaria (riparazioni, sostituzione componenti rotti/usurati)
  UPGRADE // Upgrade/migliorie hardware o software
  OTHER // Altro tipo di intervento

  @@schema("print-farm")
}

/// Stato sessione manutenzione (toggle + tracking ore + PDF ISO).
enum MaintenanceSessionStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED

  @@schema("print-farm")
}

enum MaintenanceChatRole {
  USER
  ASSISTANT
  SYSTEM

  @@schema("print-farm")
}

/// Modalità di ricorrenza per la pianificazione manutenzioni.
enum MaintenanceRecurrenceMode {
  /// Pianificazione una tantum (no ricorrenza): genera una sola occorrenza.
  NONE
  /// Ogni N giorni (intervalValue = N).
  DAILY
  /// Ogni N settimane.
  WEEKLY
  /// Ogni N mesi (es. mensile = 1).
  MONTHLY
  /// Ogni N anni.
  YEARLY

  @@schema("print-farm")
}

/// Esito conclusivo dell'intervento di manutenzione (campo ISO 9001).
enum MaintenanceOutcome {
  /// Intervento eseguito con esito positivo, nessuna anomalia.
  OK
  /// Esito positivo ma con note/raccomandazioni (es. "valutare sostituzione cinghia al prossimo intervento").
  OK_WITH_NOTES
  /// Problema non risolto, richiede intervento successivo (apertura nuova manutenzione consigliata).
  NOT_RESOLVED
  /// Rimandato (es. ricambio non disponibile, da rischedulare).
  POSTPONED

  @@schema("print-farm")
}

/// Origine dell'issue (telemetria o operatore/scheduler).
enum PrinterIssueSource {
  MQTT
  WSS
  OPERATOR
  SCHEDULER

  @@schema("print-farm")
}

/// Categoria operativa/tecnica dell'issue.
enum PrinterIssueCategory {
  FILAMENT // fine filamento, carico/estrusione, AMS ecc
  BED // scarico piatto / adesione / pulizia
  PRINT // errore durante stampa
  NETWORK // offline / timeout
  MAINTENANCE // guasti / manutenzione richiesta
  SAFETY // sportello aperto, temperatura, ecc
  OTHER

  @@schema("print-farm")
}

/// Stato lifecycle dell'issue.
enum PrinterIssueStatus {
  OPEN
  ACKED
  RESOLVED

  @@schema("print-farm")
}

enum FailureReason {
  BED_ADHESION // Distacco dal piatto
  NOZZLE_CLOG // Ugello intasato
  FILAMENT_ISSUE // Filamento spezzato/finito/umido
  LAYER_SHIFT // Perdita passi
  POWER_LOSS // Blackout
  SPAGHETTI // Stampa nel vuoto
  QUALITY_ISSUE // Brutta finitura
  USER_ERROR // Errore operatore
  SLICING_ERROR // File corrotto/errato
  OTHER

  @@schema("print-farm")
}

enum FeedbackType {
  PRINTER_ISSUE
  FILE_ISSUE
  SLICING_IMPROVEMENT
  MODIFICATION_REQUEST // Richiesta di modifica del file
  GENERAL

  @@schema("print-farm")
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WONT_FIX

  @@schema("print-farm")
}

enum FeedbackPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("print-farm")
}
